# Foundry project endpoint. Hosted containers receive this from Foundry.
# Use either variable locally; the agent checks both (FOUNDRY_PROJECT_ENDPOINT first).
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
# AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Model deployment name in the Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=<model-deployment-name>

# Backend Asset MCP server URL (APIM's native MCP gateway in front of the
# Backend API). Tools call ONLY this URL -- never the Backend API or Cosmos
# DB directly.
BACKEND_MCP_SERVER_URL=https://<apim-gateway>/backend-assets-mcp/mcp

# Managed-identity Cosmos DB conversation memory. CONTOSO_AGENT_MEMORY_ENDPOINT has
# no default and must be set explicitly (fail closed). CONTOSO_AGENT_MEMORY_DATABASE_PREFIX
# defaults to the Python-specific prefix below if unset -- it must never be
# set to the C# agent's shared "agent-memory-" prefix; the two hosted-agent
# profiles use separate Cosmos databases per tenant.
CONTOSO_AGENT_MEMORY_ENDPOINT=https://<agent-memory-cosmos>.documents.azure.com:443/
CONTOSO_AGENT_MEMORY_DATABASE_PREFIX=agent-memory-python-
CONTOSO_AGENT_MEMORY_CONTAINER_NAME=agentSessions
CONTOSO_AGENT_MEMORY_SESSION_TTL_SECONDS=2592000

# Optional for local telemetry. Hosted containers receive this from Foundry.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
AZURE_AI_PROJECT_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>
OTEL_RESOURCE_ATTRIBUTES=microsoft.foundry.project.id=${AZURE_AI_PROJECT_ID},gen_ai.azure_ai_project.id=${AZURE_AI_PROJECT_ID}

# Demo-only: captures prompt/completion content in GenAI traces.
# Disable for production or sensitive workloads.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true

# Port the Responses protocol host listens on (azure-ai-agentserver-core default is 8088).
PORT=8088
