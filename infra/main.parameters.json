{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "externalIdIssuer": {
      "value": "${EXTERNAL_ID_ISSUER}"
    },
    "externalIdAuthority": {
      "value": "${EXTERNAL_ID_AUTHORITY}"
    },
    "apiAudience": {
      "value": "${API_AUDIENCE}"
    },
    "frontendApiClientId": {
      "value": "${FRONTEND_API_CLIENT_ID}"
    },
    "backendServiceAuthority": {
      "value": "${BACKEND_SERVICE_AUTHORITY}"
    },
    "backendServiceIssuer": {
      "value": "${BACKEND_SERVICE_ISSUER}"
    },
    "backendApiAudience": {
      "value": "${BACKEND_API_AUDIENCE}"
    },
    "backendApiServiceTokenScope": {
      "value": "${BACKEND_API_SERVICE_TOKEN_SCOPE}"
    },
    "apimPublisherEmail": {
      "value": "${APIM_PUBLISHER_EMAIL}"
    },
    "apimPublisherName": {
      "value": "${APIM_PUBLISHER_NAME}"
    },
    "alertActionGroupEmail": {
      "value": "${ALERT_ACTION_GROUP_EMAIL}"
    },
    "foundryLocation": {
      "value": "${FOUNDRY_LOCATION=eastus2}"
    },
    "foundryModelDeploymentName": {
      "value": "${AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini}"
    },
    "foundryModelName": {
      "value": "${FOUNDRY_MODEL_NAME=gpt-4.1-mini}"
    },
    "foundryModelVersion": {
      "value": "${FOUNDRY_MODEL_VERSION=2025-04-14}"
    },
    "foundryModelSkuName": {
      "value": "${FOUNDRY_MODEL_SKU=GlobalStandard}"
    },
    "foundryModelCapacity": {
      "value": "${FOUNDRY_MODEL_CAPACITY=10}"
    },
    "portfolioAgentResponsesEndpoint": {
      "value": "${AGENT_PORTFOLIO_AGENT_RESPONSES_ENDPOINT=}"
    },
    "portfolioAgentInvocationsEndpoint": {
      "value": "${AGENT_PORTFOLIO_AGENT_INVOCATIONS_ENDPOINT=}"
    },
    "portfolioAgentPrincipalId": {
      "value": "${PORTFOLIO_AGENT_PRINCIPAL_ID=}"
    },
    "portfolioAgentPythonPrincipalId": {
      "value": "${PORTFOLIO_AGENT_PYTHON_PRINCIPAL_ID=}"
    },
    "developerPrincipalId": {
      "value": "${AZURE_PRINCIPAL_ID=}"
    },
    "developerPrincipalType": {
      "value": "${AZURE_PRINCIPAL_TYPE=User}"
    },
    "enableJumpbox": {
      "value": "${ENABLE_JUMPBOX=false}"
    },
    "jumpboxUserPrincipalId": {
      "value": "${JUMPBOX_USER_PRINCIPAL_ID=}"
    },
    "jumpboxUserPrincipalType": {
      "value": "${JUMPBOX_USER_PRINCIPAL_TYPE=User}"
    },
    "jumpboxVmSize": {
      "value": "${JUMPBOX_VM_SIZE=Standard_D2als_v7}"
    },
    "jumpboxAdminUsername": {
      "value": "${JUMPBOX_ADMIN_USERNAME=jumpboxadmin}"
    },
    "jumpboxShutdownTime": {
      "value": "${JUMPBOX_SHUTDOWN_TIME=1900}"
    },
    "jumpboxShutdownTimeZone": {
      "value": "${JUMPBOX_SHUTDOWN_TIME_ZONE=UTC}"
    }
  }
}
